# Copy this file to .env or load it in your hosting platform for each store.

# Store identity
STORE_PROFILE_CODE=default
STORE_NAME="Your Store"
STORE_LEGAL_NAME="Your Store LLC"
STORE_COUNTRY="Country"
STORE_LOCATION_TEXT="Online store"
STORE_EMAIL="support@your-store.example"
STORE_SUPPORT_EMAIL="support@your-store.example"
ADMIN_MAIL="orders@your-store.example"
STORE_PHONE="+00000000000"
STORE_PHONE_DISPLAY="+000 0000 0000"
STORE_PHONE_COUNTRY_CODE="+000"
STORE_WHATSAPP_URL="https://wa.me/00000000000"
STORE_INSTAGRAM_URL=""
STORE_INSTAGRAM_HANDLE="@your-store"
STORE_TIKTOK_URL=""
STORE_LOGO="/static/logo.png"
STORE_SECONDARY_LOGO="/static/logo.png"
STORE_HERO_IMAGE="/static/hero.jpg"

# Theme
STORE_PRIMARY_COLOR="#111111"
STORE_ACCENT_COLOR="#d97706"
STORE_BACKGROUND_COLOR="#ffffff"
STORE_SURFACE_COLOR="#fafafa"
STORE_TEXT_COLOR="#1a1a1a"
STORE_MUTED_TEXT_COLOR="#6b7280"
STORE_FONT="Inter"
STORE_HEADING_FONT="Oswald"
STORE_ARABIC_FONT="Cairo"
STORE_BUTTON_RADIUS="0px"
STORE_CARD_RADIUS="4px"
STORE_LOGO_WIDTH="60px"
STORE_LOGO_HEIGHT="60px"
STORE_HERO_OVERLAY="rgba(0, 0, 0, 0.10)"
STORE_HERO_POSITION="center 30%"

# Homepage sections
SHOW_FEATURED_CATEGORIES=true
SHOW_WHY_US=true
SHOW_REVIEWS=true
SHOW_NEWSLETTER=true
SHOW_POLICIES=true

# Homepage copy
STORE_HERO_TITLE_EN="Your Store"
STORE_HERO_SUBTITLE_EN="Discover our latest collection"
STORE_HERO_TITLE_AR="Your Store"
STORE_HERO_SUBTITLE_AR="اكتشف مجموعتنا المختارة"
STORE_WHY_TITLE_EN="Why Choose Us?"
STORE_WHY_SUBTITLE_EN="Quality products, clear service, and fast delivery."
STORE_FOOTER_ABOUT_EN="Premium products selected for your lifestyle."
STORE_FOOTER_ABOUT_AR="منتجات مختارة بعناية تناسب أسلوب حياتك."

# Checkout shipping zones
# Format: name|label|phone_code|shipping_label|shipping_rate|free_shipping_threshold;name2|label2|phone2|label2|rate2|threshold2
CHECKOUT_SHIPPING_ZONES="Country|Country|+000|Standard Delivery|0|0"

# Payment options
ENABLE_COD=true
ENABLE_TAP=true
ENABLE_BENEFITPAY=true
ENABLE_CARD_PAYMENT=true
TAP_SECRET_KEY=""
TAP_PUBLIC_KEY=""

# Mail
MAIL_SERVER="mail.privateemail.com"
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME="support@your-store.example"
MAIL_PASSWORD=""
MAIL_SENDER_NAME="Your Store"
MAIL_DEFAULT_SENDER="support@your-store.example"
EMAIL_BRAND_COLOR="#111111"
EMAIL_ACCENT_COLOR="#d97706"
EMAIL_RECEIPT_SUBJECT="Order Confirmation #{order_id} - {store_name}"
EMAIL_ADMIN_SUBJECT="NEW ORDER #{order_id} | {amount} {currency} | {status}"
EMAIL_SUPPORT_CTA="Need help? Contact our support team."

# SEO / social previews
SEO_TITLE="Your Store"
SEO_DESCRIPTION="Shop online from Your Store"
SEO_KEYWORDS=""
SEO_OG_IMAGE="/static/hero.jpg"
SEO_WHATSAPP_IMAGE="/static/hero.jpg"

# Policies
POLICY_LAST_UPDATED="Latest update"
POLICY_SHIPPING_INTRO="Delivery options, timing, and fees depend on your selected area."
POLICY_SHIPPING_POINT_1="Shipping zones and rates are configured per store."
POLICY_SHIPPING_POINT_2="Customers receive order updates after checkout."
POLICY_SHIPPING_POINT_3="Contact support for special delivery requests."
POLICY_REFUND_RULE="Refund and return eligibility depends on the store policy."
POLICY_REFUND_PROCESS="Contact support with your order number to start a request."
POLICY_REFUND_CONDITION="Items must meet the configured return conditions."
POLICY_REFUND_NOTE="Shipping fees may be non-refundable unless required by the store policy."
POLICY_PRIVACY_INTRO="Customer information is used to process orders and provide support."
POLICY_PRIVACY_POINT_1="We collect checkout and contact information needed for orders."
POLICY_PRIVACY_POINT_2="We do not sell customer information."
POLICY_TERMS="By placing an order, customers agree to the configured store terms."

# Product translation glossary
# Format: english phrase:arabic phrase;another phrase:another translation
STORE_GLOSSARY=""

# Shipping provider pickup details
STORE_PICKUP_ADDRESS=""
STORE_PICKUP_LNG="0"
STORE_PICKUP_LAT="0"
STORE_DISPATCH_NAME="Store Dispatch"
STORE_DISPATCH_EMAIL="support@your-store.example"
SHIPPING_BASE_URL=""
SHIPPING_CLIENT_ID=""
SHIPPING_CLIENT_SECRET=""
SHIPPING_CUSTOMER_ID=""
